<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="UTF-8">


    <meta name="viewport" content="width=device-width, initial-scale=1.0">


    <title>Add Recipe | RecipeHub</title>


    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">


    <link rel="stylesheet" href="/css/style.css">


</head>

<body>

    <%- include("navbar") %>


        <section class="recipe-page-header">


            <div class="container">


                <div class="recipe-header-content">

                    <h1>

                        Share Your Recipe

                    </h1>


                    <p>

                        Add your delicious recipe and share it

                        with the RecipeHub community.

                    </p>


                </div>


            </div>


        </section>


        <section class="recipe-form-section">


            <div class="container">


                <div class="row justify-content-center">


                    <div class="col-12 col-lg-9 col-xl-8">


                        <div class="recipe-form-card">


                            <!-- FORM HEADER -->


                            <div class="form-card-header">


                                <div>


                                    <h3>

                                        🍽️ Recipe Details

                                    </h3>


                                    <p>

                                        Fill in the details below

                                    </p>

                                </div>


                                <span class="required-note">

                                    * Required fields

                                </span>


                            </div>


                            <!-- FORM -->


                            <form action="/recipes/add" method="POST" enctype="multipart/form-data">


                                <div class="row g-4">


                                    <!-- RECIPE NAME -->


                                    <div class="col-12">


                                        <label for="title" class="form-label">


                                            Recipe Name

                                            <span>*</span>


                                        </label>


                                        <input type="text" id="title" name="title" class="form-control"
                                            placeholder="e.g. Creamy Garlic Pasta" required>


                                    </div>


                                    <!-- DESCRIPTION -->


                                    <div class="col-12">


                                        <label for="description" class="form-label">


                                            Description

                                            <span>*</span>


                                        </label>


                                        <textarea id="description" name="description" class="form-control" rows="5"
                                            placeholder="Tell us about your delicious recipe..." required></textarea>


                                    </div>

                                    <!-- INGREDIENTS -->

                                    <div class="col-12">

                                        <label for="ingredients" class="form-label">

                                            Ingredients

                                            <span>*</span>

                                        </label>


                                        <textarea id="ingredients" name="ingredients" class="form-control" rows="6"
                                            placeholder="Example:
2 cups flour
1 cup milk
2 eggs
1 tablespoon sugar" required></textarea>


                                        <small class="form-help">

                                            Add each ingredient on a new line.

                                        </small>

                                    </div>


                                    <!-- CATEGORY -->


                                    <div class="col-12 col-md-6">


                                        <label for="category" class="form-label">


                                            Category

                                            <span>*</span>


                                        </label>


                                        <select id="category" name="category" class="form-select" required>


                                            <option value="" selected disabled>


                                                Select Category

                                            </option>


                                            <option value="Breakfast">


                                                🍳 Breakfast

                                            </option>


                                            <option value="Lunch">


                                                🍱 Lunch

                                            </option>


                                            <option value="Dinner">


                                                🍽️ Dinner

                                            </option>


                                            <option value="Snacks">


                                                🍟 Snacks

                                            </option>


                                            <option value="Dessert">


                                                🍰 Dessert

                                            </option>


                                            <option value="Beverages">


                                                🥤 Beverages

                                            </option>


                                        </select>


                                    </div>


                                    <!-- IMAGE -->


                                    <div class="col-12 col-md-6">


                                        <label for="image" class="form-label">


                                            Recipe Image

                                            <span>*</span>


                                        </label>


                                        <input type="file" id="image" name="image" class="form-control"
                                            accept="image/png,image/jpeg,image/webp" required>


                                        <small class="form-help">


                                            JPG, PNG or WEBP only

                                        </small>


                                    </div>


                                    <!-- PRICE -->


                                    <div class="col-12 col-md-6">


                                        <label for="price" class="form-label">


                                            Recipe Price

                                            <span>*</span>


                                        </label>


                                        <div class="input-group">


                                            <span class="input-group-text">


                                                ₹

                                            </span>


                                            <input type="number" id="price" name="price" class="form-control"
                                                placeholder="Enter price" min="0" required>


                                        </div>


                                    </div>


                                    <!-- QUANTITY -->


                                    <div class="col-12 col-md-6">


                                        <label for="quantity" class="form-label">


                                            Available Quantity

                                            <span>*</span>


                                        </label>


                                        <input type="number" id="quantity" name="quantity" class="form-control"
                                            placeholder="Enter quantity" min="1" required>


                                    </div>


                                </div>


                                <!-- ACTION BUTTONS -->


                                <div class="form-actions">


                                    <a href="/recipes/dashboard" class="btn btn-cancel">


                                        Cancel

                                    </a>


                                    <button type="submit" class="btn btn-submit">


                                        🍳 Add Recipe

                                    </button>


                                </div>


                            </form>


                        </div>


                    </div>


                </div>


            </div>


        </section>


        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">

        </script>

</body>

</html>