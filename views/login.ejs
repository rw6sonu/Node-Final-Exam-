<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Login | RecipeHub</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">

    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link
        href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Poppins:wght@400;500;600;700&display=swap"
        rel="stylesheet">

    <link rel="stylesheet" href="/css/style.css">


</head>

<body class="auth-page">

    <div class="auth-wrapper">

        <!-- LEFT SIDE IMAGE -->

        <div class="auth-image">

            <div class="image-overlay">

                <div class="brand-logo">
                    🍴 RecipeHub
                </div>

                <div class="image-content">

                    <span class="small-heading">
                        WELCOME BACK TO THE KITCHEN
                    </span>

                    <h1>
                        Cook something
                        <br>
                        <span>delicious today.</span>
                    </h1>

                    <p>
                        Discover amazing recipes, share your
                        favorite dishes, and bring people together
                        through the love of food.
                    </p>

                </div>

                <div class="food-quote">

                    <span>“</span>

                    <p>
                        Good food is the foundation
                        of genuine happiness.
                    </p>

                </div>

            </div>

        </div>


        <!-- RIGHT SIDE LOGIN FORM -->

        <div class="auth-form-section">

            <div class="auth-form-box">

                <div class="mobile-logo">
                    🍴 RecipeHub
                </div>


                <div class="form-heading">

                    <span class="form-icon">
                        👋
                    </span>

                    <h2>
                        Welcome back!
                    </h2>

                    <p>
                        Sign in to continue your culinary journey.
                    </p>

                </div>


                <form action="/login" method="POST">


                    <div class="input-group">

                        <label for="email">
                            Email Address
                        </label>

                        <div class="input-wrapper">

                            <span class="input-icon">
                                ✉
                            </span>

                            <input type="email" id="email" name="email" placeholder="Enter your email" required>

                        </div>

                    </div>


                    <div class="input-group">

                        <div class="password-label">

                            <label for="password">
                                Password
                            </label>

                            <a href="#">
                                Forgot Password?
                            </a>

                        </div>


                        <div class="input-wrapper">

                            <span class="input-icon">
                                🔒
                            </span>

                            <input type="password" id="password" name="password" placeholder="Enter your password"
                                required>

                            <button type="button" class="show-password" onclick="togglePassword()">

                                👁

                            </button>

                        </div>

                    </div>


                    <div class="remember-me">

                        <label>

                            <input type="checkbox">

                            <span>
                                Remember me
                            </span>

                        </label>

                    </div>


                    <button type="submit" class="login-btn">

                        <span>
                            Login to RecipeHub
                        </span>

                        <span>
                            →
                        </span>

                    </button>


                </form>


                <div class="divider">

                    <span>
                        OR
                    </span>

                </div>


                <p class="register-text">

                    Don't have an account?

                    <a href="/register">
                        Create an account
                    </a>

                </p>


                <p class="bottom-text">

                    🍳 Made for food lovers, by food lovers

                </p>

            </div>

        </div>

    </div>

    <% if (success && success.length > 0) { %>

    <div class="flash-message success-message">

        <span>✓</span>

        <%= success[0] %>

    </div>

<% } %>


<% if (error && error.length > 0) { %>

    <div class="flash-message error-message">

        <span>!</span>

        <%= error[0] %>

    </div>

<% } %>


    <script>

        function togglePassword() {

            const passwordInput =
                document.getElementById("password");

            const button =
                document.querySelector(".show-password");


            if (
                passwordInput.type === "password"
            ) {

                passwordInput.type = "text";

                button.textContent = "🙈";

            } else {

                passwordInput.type = "password";

                button.textContent = "👁";

            }

        }

    </script>


</body>

</html>