<!DOCTYPE html>

<html lang="en">

<head>


<meta charset="UTF-8">

<meta name="viewport"
    content="width=device-width, initial-scale=1.0">

<title>
    All Recipes | RecipeHub
</title>


<!-- BOOTSTRAP -->

<link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet">


<!-- CUSTOM CSS -->

<link
    rel="stylesheet"
    href="/css/style.css">


</head>

<body>


<!-- NAVBAR -->

<%- include("navbar") %>


<!-- PAGE HEADER -->

<section class="recipe-list-header">

    <div class="container">

        <div
            class="d-flex justify-content-between align-items-center flex-wrap gap-3">


            <div>

                <h1 class="mt-5">

                    🍽️ All Recipes

                </h1>


                <p>

                    Manage all recipes from one place.

                </p>

            </div>


            <a
                href="/recipes/add"
                class="btn btn-warning">


                ➕ Add Recipe


            </a>


        </div>

    </div>

</section>


<!-- RECIPES TABLE -->

<section class="recipe-table-section">

    <div class="container">


        <div class="card recipe-table-card">


            <div class="card-body">


                <div class="table-responsive">


                    <table
                        class="table table-hover align-middle">


                        <thead>


                            <tr>


                                <th>

                                    #

                                </th>


                                <th>

                                    Image

                                </th>


                                <th>

                                    Recipe Name

                                </th>


                                <th>

                                    Category

                                </th>


                                <th>

                                    Description

                                </th>


                                <th>

                                    Ingredients

                                </th>


                                <th>

                                    Price

                                </th>


                                <th>

                                    Quantity

                                </th>


                                <th>

                                    Actions

                                </th>


                            </tr>


                        </thead>


                        <tbody>


                            <% if (recipes && recipes.length > 0) { %>


                                <% recipes.forEach((recipe, index) => { %>


                                    <tr>


                                        <!-- NUMBER -->


                                        <td>

                                            <%= index + 1 %>

                                        </td>


                                        <!-- IMAGE -->


                                        <td>


                                            <% if (recipe.image) { %>


                                                <img

                                                    src="/uploads/<%= recipe.image %>"

                                                    alt="<%= recipe.title %>"

                                                    class="recipe-table-image">


                                            <% } else { %>


                                                <div
                                                    class="no-image">


                                                    🍽️


                                                </div>


                                            <% } %>


                                        </td>


                                        <!-- NAME -->


                                        <td>


                                            <strong>

                                                <%= recipe.title %>

                                            </strong>


                                        </td>


                                        <!-- CATEGORY -->


                                        <td>


                                            <span
                                                class="badge category-badge">


                                                <%= recipe.category %>


                                            </span>


                                        </td>


                                        <!-- DESCRIPTION -->


                                        <td>


                                            <span
                                                class="description-text">


                                                <%= recipe.description.length > 50

                                                    ? recipe.description.substring(0, 50) + "..."

                                                    : recipe.description %>


                                            </span>


                                        </td>


                                        <!-- INGREDIENTS -->


                                        <td>


                                            <span
                                                class="description-text">


                                                <%= recipe.ingredients.length > 40

                                                    ? recipe.ingredients.substring(0, 40) + "..."

                                                    : recipe.ingredients %>


                                            </span>


                                        </td>


                                        <!-- PRICE -->


                                        <td>


                                            <strong>

                                                ₹<%= recipe.price %>

                                            </strong>


                                        </td>


                                        <!-- QUANTITY -->


                                        <td>


                                            <span
                                                class="badge quantity-badge text-black">


                                                <%= recipe.quantity %>


                                            </span>


                                        </td>


                                        <!-- ACTIONS -->


                                        <td>


                                            <div
                                                class="d-flex gap-2">


                                                <a

                                                    href="/recipes/edit/<%= recipe._id %>"

                                                    class="btn btn-sm btn-primary">


                                                    ✏️ Edit


                                                </a>


                                                <a

                                                    href="/recipes/delete/<%= recipe._id %>"

                                                    class="btn btn-sm btn-danger"

                                                    onclick="return confirm('Are you sure you want to delete this recipe?')">


                                                    🗑️ Delete


                                                </a>


                                            </div>


                                        </td>


                                    </tr>


                                <% }) %>


                            <% } else { %>


                                <tr>


                                    <td

                                        colspan="9"

                                        class="text-center py-5">


                                        <div
                                            class="empty-state">


                                            🍽️


                                            <h4>

                                                No Recipes Found


                                            </h4>


                                            <p>

                                                Start by adding your first recipe.

                                            </p>


                                            <a

                                                href="/recipes/add"

                                                class="btn btn-warning">


                                                ➕ Add Recipe


                                            </a>


                                        </div>


                                    </td>


                                </tr>


                            <% } %>


                        </tbody>


                    </table>

                </div>

            </div>

        </div>

    </div>

</section>


<!-- BOOTSTRAP JS -->


<script

    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">

</script>


</body>

</html>
