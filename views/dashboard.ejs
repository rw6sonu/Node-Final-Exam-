<!DOCTYPE html>

<html lang="en">

<head>


<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Dashboard | RecipeHub</title>

<link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet">

<link
    rel="stylesheet"
    href="/css/style.css">


</head>

<body>


<!-- NAVBAR -->

<%- include("navbar") %>


<!-- DASHBOARD HEADER -->

<section class="dashboard-header">

    <div class="container">

        <div class="dashboard-welcome">

            <div>

                <p class="dashboard-small-title">

                    👋 WELCOME BACK

                </p>

                <h1>

                    RecipeHub Dashboard

                </h1>

                <p>

                    Manage your recipes and users from one place.

                </p>

            </div>

        </div>

    </div>

</section>


<!-- DASHBOARD CONTENT -->

<section class="dashboard-section">

    <div class="container">


        <!-- STAT CARDS -->

        <div class="row g-4">


            <!-- TOTAL USERS -->

            <div class="col-12 col-md-6 col-lg-4">

                <div class="dashboard-card users-card">

                    <div class="dashboard-card-icon">

                        👥

                    </div>

                    <div>

                        <p>

                            Total Users

                        </p>

                        <h2>

                            <%= totalUsers %>

                        </h2>

                    </div>

                </div>

            </div>


            <!-- TOTAL RECIPES -->

            <div class="col-12 col-md-6 col-lg-4">

                <div class="dashboard-card recipes-card">

                    <div class="dashboard-card-icon">

                        🍽️

                    </div>

                    <div>

                        <p>

                            Total Recipes

                        </p>

                        <h2>

                            <%= totalRecipes %>

                        </h2>

                    </div>

                </div>

            </div>


            <!-- QUICK ADD -->

            <div class="col-12 col-md-6 col-lg-4">

                <div class="dashboard-card add-card">

                    <div class="dashboard-card-icon">

                        ➕

                    </div>

                    <div>

                        <p>

                            Add New Recipe

                        </p>

                        <a
                            href="/recipes/add"
                            class="dashboard-action-btn">

                            Add Recipe

                        </a>

                    </div>

                </div>

            </div>


        </div>


        <!-- QUICK ACTIONS -->

        <div class="dashboard-bottom mt-5">


            <div class="dashboard-section-title">

                <h3>

                    Quick Actions

                </h3>

                <p>

                    Manage your RecipeHub easily.

                </p>

            </div>


            <div class="row g-4">


                <!-- VIEW RECIPES -->

                <div class="col-12 col-md-6">

                    <a
                        href="/recipes/view"
                        class="quick-action-card">


                        <div class="quick-action-icon">

                            🍴

                        </div>


                        <div>

                            <h4>

                                View All Recipes

                            </h4>

                            <p>

                                View, edit and delete all recipes.

                            </p>

                        </div>


                        <span class="arrow">

                            →

                        </span>


                    </a>

                </div>


                <!-- ADD RECIPE -->

                <div class="col-12 col-md-6">

                    <a
                        href="/recipes/add"
                        class="quick-action-card">


                        <div class="quick-action-icon">

                            📝

                        </div>


                        <div>

                            <h4>

                                Add New Recipe

                            </h4>

                            <p>

                                Create a new delicious recipe.

                            </p>

                        </div>


                        <span class="arrow">

                            →

                        </span>


                    </a>

                </div>


            </div>

        </div>


    </div>

</section>


<script
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">
</script>


</body>

</html>
