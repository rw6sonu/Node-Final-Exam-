<!DOCTYPE html>

<html lang="en">

<head>


<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Edit Recipe | RecipeHub</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet" href="/css/style.css">


</head>

<body>


<%- include("navbar") %>


<!-- PAGE HEADER -->

<section class="recipe-page-header">

    <div class="container">

        <div class="recipe-header-content">

            <h1>

                Edit Your Recipe

            </h1>

            <p>

                Update your delicious recipe details.

            </p>

        </div>

    </div>

</section>


<!-- FORM SECTION -->

<section class="recipe-form-section">

    <div class="container">

        <div class="row justify-content-center">

            <div class="col-12 col-lg-9 col-xl-8">

                <div class="recipe-form-card">


                    <!-- FORM HEADER -->

                    <div class="form-card-header">

                        <div>

                            <h3>

                                🍽️ Edit Recipe Details

                            </h3>

                            <p>

                                Update the details below

                            </p>

                        </div>

                        <span class="required-note">

                            * Required fields

                        </span>

                    </div>


                    <!-- FORM -->

                    <form

                        action="/recipes/edit/<%= recipe._id %>"

                        method="POST"

                        enctype="multipart/form-data">


                        <div class="row g-4">


                            <!-- RECIPE NAME -->

                            <div class="col-12">

                                <label for="title" class="form-label">

                                    Recipe Name

                                    <span>*</span>

                                </label>

                                <input

                                    type="text"

                                    id="title"

                                    name="title"

                                    class="form-control"

                                    value="<%= recipe.title %>"

                                    placeholder="e.g. Creamy Garlic Pasta"

                                    required>

                            </div>


                            <!-- DESCRIPTION -->

                            <div class="col-12">

                                <label for="description" class="form-label">

                                    Description

                                    <span>*</span>

                                </label>

                                <textarea

                                    id="description"

                                    name="description"

                                    class="form-control"

                                    rows="5"

                                    placeholder="Tell us about your delicious recipe..."

                                    required><%= recipe.description %></textarea>

                            </div>


                            <!-- INGREDIENTS -->

                            <div class="col-12">

                                <label for="ingredients" class="form-label">

                                    Ingredients

                                    <span>*</span>

                                </label>

                                <textarea

                                    id="ingredients"

                                    name="ingredients"

                                    class="form-control"

                                    rows="6"

                                    placeholder="Example:


2 cups flour
1 cup milk
2 eggs
1 tablespoon sugar"


                                    required><%= recipe.ingredients %></textarea>

                                <small class="form-help">

                                    Add each ingredient on a new line.

                                </small>

                            </div>


                            <!-- CATEGORY -->

                            <div class="col-12 col-md-6">

                                <label for="category" class="form-label">

                                    Category

                                    <span>*</span>

                                </label>

                                <select

                                    id="category"

                                    name="category"

                                    class="form-select"

                                    required>


                                    <option value="" disabled>

                                        Select Category

                                    </option>


                                    <option

                                        value="Breakfast"

                                        <%= recipe.category === "Breakfast" ? "selected" : "" %>>

                                        🍳 Breakfast

                                    </option>


                                    <option

                                        value="Lunch"

                                        <%= recipe.category === "Lunch" ? "selected" : "" %>>

                                        🍱 Lunch

                                    </option>


                                    <option

                                        value="Dinner"

                                        <%= recipe.category === "Dinner" ? "selected" : "" %>>

                                        🍽️ Dinner

                                    </option>


                                    <option

                                        value="Snacks"

                                        <%= recipe.category === "Snacks" ? "selected" : "" %>>

                                        🍟 Snacks

                                    </option>


                                    <option

                                        value="Dessert"

                                        <%= recipe.category === "Dessert" ? "selected" : "" %>>

                                        🍰 Dessert

                                    </option>


                                    <option

                                        value="Beverages"

                                        <%= recipe.category === "Beverages" ? "selected" : "" %>>

                                        🥤 Beverages

                                    </option>


                                </select>

                            </div>


                            <!-- IMAGE -->

                            <div class="col-12 col-md-6">

                                <label for="image" class="form-label">

                                    Recipe Image

                                </label>

                                <input

                                    type="file"

                                    id="image"

                                    name="image"

                                    class="form-control"

                                    accept="image/png,image/jpeg,image/webp">


                                <small class="form-help">

                                    Leave empty to keep the current image.

                                </small>


                                <% if (recipe.image) { %>

                                    <div class="mt-3">

                                        <img

                                            src="/uploads/<%= recipe.image %>"

                                            alt="<%= recipe.title %>"

                                            style="width: 100px; height: 80px; object-fit: cover; border-radius: 8px;">

                                    </div>

                                <% } %>

                            </div>


                            <!-- PRICE -->

                            <div class="col-12 col-md-6">

                                <label for="price" class="form-label">

                                    Recipe Price

                                    <span>*</span>

                                </label>

                                <div class="input-group">

                                    <span class="input-group-text">

                                        ₹

                                    </span>

                                    <input

                                        type="number"

                                        id="price"

                                        name="price"

                                        class="form-control"

                                        value="<%= recipe.price %>"

                                        min="0"

                                        required>

                                </div>

                            </div>


                            <!-- QUANTITY -->

                            <div class="col-12 col-md-6">

                                <label for="quantity" class="form-label">

                                    Available Quantity

                                    <span>*</span>

                                </label>

                                <input

                                    type="number"

                                    id="quantity"

                                    name="quantity"

                                    class="form-control"

                                    value="<%= recipe.quantity %>"

                                    min="1"

                                    required>

                            </div>


                        </div>


                        <!-- ACTION BUTTONS -->

                        <div class="form-actions">

                            <a

                                href="/recipes"

                                class="btn btn-cancel">

                                Cancel

                            </a>


                            <button

                                type="submit"

                                class="btn btn-submit">

                                ✏️ Update Recipe

                            </button>

                        </div>


                    </form>

                </div>

            </div>

        </div>

    </div>

</section>


<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">

</script>


</body>

</html>
